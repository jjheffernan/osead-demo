---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { t } from "../i18n/ui";
import { resolveRoute } from "../i18n/routes";
import { siteConfig } from "../config/site.config";
import BlogCard from "../components/blog/BlogCard.svelte";
import Pagination from "../components/ui/data-display/Pagination/Pagination.svelte";
import { toBlogPostSummary } from "../lib/blog";

const locale = (Astro.currentLocale || "en") as "en";
const searchParams = Astro.url.searchParams;
const currentTag = searchParams.get("tag") ?? "";
const currentPage = Math.max(1, Number(searchParams.get("page") || "1"));
const slugify = (value: string) =>
  value
    .trim()
    .toLowerCase()
    .replace(/['"]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const allPosts: CollectionEntry<"blog">[] = await getCollection("blog");
const posts = allPosts
  .filter((p) => p.data.locale === locale && !p.data.draft)
  .sort(
    (a, b) =>
      new Date(b.data.publishDate).getTime() -
      new Date(a.data.publishDate).getTime(),
  );

const filteredPosts = currentTag
  ? posts.filter((post) =>
      (post.data.tags ?? []).some((tag: string) => slugify(tag) === currentTag),
    )
  : posts;
const featuredPost =
  currentPage === 1
    ? (filteredPosts.find((post) => post.data.featured) ?? filteredPosts[0])
    : undefined;
const gridPosts = featuredPost
  ? filteredPosts.filter((post) => post.id !== featuredPost.id)
  : filteredPosts;
const postsPerPage = siteConfig.blog.postsPerPage;
const totalPages = Math.max(1, Math.ceil(gridPosts.length / postsPerPage));
const pagePosts = gridPosts.slice(
  (currentPage - 1) * postsPerPage,
  currentPage * postsPerPage,
);
const allTags = [
  ...new Set(posts.flatMap((post) => post.data.tags || [])),
]
  .map((tag) => ({
    label: tag,
    slug: slugify(tag),
    count: posts.filter((post) =>
      (post.data.tags ?? []).some((t: string) => slugify(t) === slugify(tag)),
    ).length,
  }))
  .sort((a, b) => b.count - a.count || a.label.localeCompare(b.label));

function titleCaseTag(tag: string): string {
  return tag
    .split(/\s+/)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
}
---

<BaseLayout
  title={t(locale, "nav.blog")}
  description={t(locale, "nav.blog")}
  locale={locale}
  path={resolveRoute(locale, "/blog")}
>
  <main class="blog-list container py-12">
    <header class="blog-list__hero">
      <h1>{t(locale, "nav.blog")}</h1>
      <p class="blog-list__lead">
        Field notes on coastal stays, homeownership, and the places between.
      </p>
      <p class="blog-list__count">
        {filteredPosts.length}
        {filteredPosts.length === 1 ? " article" : " articles"}
        {
          currentTag && (
            <>
              {" "}
              in{" "}
              <strong>
                {titleCaseTag(
                  allTags.find((tag) => tag.slug === currentTag)?.label ??
                    currentTag,
                )}
              </strong>
            </>
          )
        }
      </p>
    </header>

    {
      allTags.length > 0 && (
        <nav class="blog-list__tags" aria-label={t(locale, "blog.filterByTag")}>
          <div class="blog-list__tags-track">
            <a
              href={resolveRoute(locale, "/blog")}
              class={`blog-chip${currentTag ? "" : " blog-chip--active"}`}
            >
              All
              <span class="blog-chip__count">{posts.length}</span>
            </a>
            {allTags.map((tag) => {
              const active = currentTag === tag.slug;
              const href = active
                ? resolveRoute(locale, "/blog")
                : `${resolveRoute(locale, "/blog")}?tag=${tag.slug}`;
              return (
                <a
                  href={href}
                  class={`blog-chip${active ? " blog-chip--active" : ""}`}
                >
                  {titleCaseTag(tag.label)}
                  <span class="blog-chip__count">{tag.count}</span>
                </a>
              );
            })}
          </div>
        </nav>
      )
    }

    {
      filteredPosts.length === 0 && (
        <div class="blog-list__empty">
          <p class="blog-list__empty-title">{t(locale, "blog.noResults")}</p>
          <a class="blog-list__empty-cta" href={resolveRoute(locale, "/blog")}>
            {t(locale, "blog.allPosts")}
          </a>
        </div>
      )
    }

      {
        featuredPost && currentPage === 1 && (
          <section class="blog-list__featured" aria-label="Featured article">
            <BlogCard
              post={toBlogPostSummary(featuredPost, locale)}
              variant="list"
              locale={locale}
              headingLevel="h2"
            />
          </section>
        )
      }

      {
        pagePosts.length > 0 && (
          <section class="blog-list__grid">
            {pagePosts.map((post) => (
              <BlogCard
                post={toBlogPostSummary(post, locale)}
                variant="grid"
                locale={locale}
                headingLevel="h2"
              />
            ))}
          </section>
        )
      }

    {
      totalPages > 1 && (
        <Pagination
          currentPage={currentPage}
          totalPages={totalPages}
          basePath={resolveRoute(locale, "/blog")}
          query={currentTag ? { tag: currentTag } : undefined}
          locale={locale}
        />
      )
    }
  </main>
</BaseLayout>

<style>
  .blog-list {
    display: grid;
    gap: var(--space-lg);
    padding-block: var(--space-lg) var(--space-xl);
  }

  .blog-list__hero {
    max-width: 48rem;
    display: grid;
    gap: var(--space-xs);
  }

  .blog-list__hero h1 {
    margin: 0;
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .blog-list__lead {
    margin: 0;
    color: var(--muted-foreground);
    font-size: 1.0625rem;
    line-height: 1.7;
  }

  .blog-list__count {
    margin: 0;
    color: var(--muted-foreground);
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
  }

  .blog-list__count strong {
    color: var(--foreground);
    font-weight: 600;
  }

  /* Filter bar — single-row scroll, no wrap clutter */
  .blog-list__tags {
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border);
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scrollbar-width: thin;
  }

  .blog-list__tags-track {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
    width: max-content;
    min-width: 100%;
    padding-bottom: 0.15rem;
  }

  .blog-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex: 0 0 auto;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 0;
    background: transparent;
    color: var(--muted-foreground);
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease;
  }

  .blog-chip__count {
    font-variant-numeric: tabular-nums;
    opacity: 0.7;
    font-weight: 500;
  }

  .blog-chip:hover {
    color: var(--foreground);
    border-color: var(--foreground);
  }

  .blog-chip--active {
    background: var(--primary);
    border-color: var(--primary);
    color: var(--primary-foreground);
  }

  .blog-chip--active .blog-chip__count {
    opacity: 0.85;
  }

  .blog-chip--active:hover {
    color: var(--primary-foreground);
  }

  /* Empty state */
  .blog-list__empty {
    display: grid;
    justify-items: center;
    gap: var(--space-md);
    padding: var(--space-xl) var(--space-lg);
    text-align: center;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-2xl);
  }

  .blog-list__empty-title {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
  }

  .blog-list__empty-cta {
    color: var(--color-brand-primary);
    font-weight: 600;
    text-decoration: none;
  }

  .blog-list__empty-cta:hover {
    text-decoration: underline;
  }

  .blog-list__grid {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr));
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-chip {
      transition: none;
    }
  }
</style>
