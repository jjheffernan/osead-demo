---
import { render } from "astro:content";
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import Breadcrumbs from "../../components/seo/Breadcrumbs.astro";
import JsonLd from "../../components/seo/JsonLd.astro";
import ListingNotice from "../../components/properties/ListingNotice.svelte";
import PropertyCard from "../../components/properties/PropertyCard.svelte";
import PropertyGallery from "../../components/properties/PropertyGallery.svelte";
import AvailabilityInquiry from "../../components/properties/AvailabilityInquiry.svelte";
import Testimonials from "../../components/testimonials/Testimonials.svelte";
import RatingSubmit from "../../components/testimonials/RatingSubmit.svelte";
import {
  getPublishedProperties,
  getRelatedProperties,
  toPropertyCardProps,
  type PropertyEntry,
} from "../../lib/properties";
import {
  buildRentalJsonLd,
  buildSaleJsonLd,
} from "../../lib/property-schema";
import { getTestimonialsFor } from "../../lib/testimonials";

export async function getStaticPaths() {
  const properties = await getPublishedProperties();
  return properties.map((property) => ({
    params: { slug: property.data.slug },
    props: { property },
  }));
}

interface Props {
  property: PropertyEntry;
}

const { property } = Astro.props;
const { data } = property;
const { Content } = await render(property);
const locale = (Astro.currentLocale || "en") as "en";
const path = `/properties/${data.slug}`;
const pageUrl = new URL(path, Astro.site).toString();
const title = data.seoTitle ?? `${data.title} | ${data.regionLabel}`;
const description = data.seoDescription ?? data.description;
const saleLd = buildSaleJsonLd(data, pageUrl);
const rentalLd = buildRentalJsonLd(data, pageUrl);
const schemas = [saleLd, rentalLd].filter(Boolean) as unknown as Record<
  string,
  unknown
>[];
const listingLabel =
  data.listingType === "both"
    ? "Rental & sale"
    : data.listingType === "rental"
      ? "Weekly rental"
      : "For sale";
// Primary IA is Rentals/Sales; markets stay secondary SEO (V13 towns).
const inventoryCrumb =
  data.listingType === "sale"
    ? { label: "Homes for Sale", href: "/sales" }
    : { label: "Weekly Rentals", href: "/rentals" };
const related = await getRelatedProperties(property);
const listingTestimonials = await getTestimonialsFor(
  "listing",
  data.slug,
  locale,
);
const showRental = data.listingType === "rental" || data.listingType === "both";
const showSale = data.listingType === "sale" || data.listingType === "both";
const saleHref = `/contact?intent=sale&property=${encodeURIComponent(data.slug)}`;
---

<MarketingLayout title={title} description={description} locale={locale} path={path}>
  {schemas.length > 0 && <JsonLd schema={schemas} />}

  <article class="container property">
    <Breadcrumbs
      crumbs={[inventoryCrumb, { label: data.title, href: path }]}
    />
    <PropertyGallery
      client:load
      images={data.images}
      videos={data.videos}
      label={`${data.title} gallery`}
    />

    <div class="property__layout">
      <div class="property__main">
        <header class="property__header">
          <p class="property__eyebrow">
            {listingLabel} · {data.regionLabel} · {data.waterfront}
          </p>
          <h1>{data.title}</h1>
          <p class="property__desc">{data.description}</p>
          {
            data.priceDisplay && (
              <p class="property__price">{data.priceDisplay}</p>
            )
          }
          <dl class="property__facts">
            <div>
              <dt>Beds</dt>
              <dd>{data.beds}</dd>
            </div>
            <div>
              <dt>Baths</dt>
              <dd>{data.baths}</dd>
            </div>
            {
              data.sleeps && (
                <div>
                  <dt>Sleeps</dt>
                  <dd>{data.sleeps}</dd>
                </div>
              )
            }
            {
              data.sqft && (
                <div>
                  <dt>Sq ft</dt>
                  <dd>{data.sqft.toLocaleString()}</dd>
                </div>
              )
            }
            {
              data.yearBuilt && (
                <div>
                  <dt>Built</dt>
                  <dd>{data.yearBuilt}</dd>
                </div>
              )
            }
          </dl>
        </header>

        {
          data.highlights.length > 0 && (
            <section class="property__section">
              <h2>Highlights</h2>
              <ul class="highlights">
                {data.highlights.map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            </section>
          )
        }

        {
          data.amenities.length > 0 && (
            <section class="property__section">
              <h2>Amenities</h2>
              <ul class="amenities">
                {data.amenities.map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            </section>
          )
        }

        <section class="property__section prose">
          <h2>About this home</h2>
          <Content />
        </section>
      </div>

      <aside class="property__aside" id="conversion-rail">
        {
          showRental && (
            <AvailabilityInquiry
              client:load
              propertySlug={data.slug}
              propertyTitle={data.title}
            />
          )
        }
        {
          showSale && (
            <a class="button" href={saleHref}>
              Schedule a showing
            </a>
          )
        }
        <a
          class="property__ask"
          href={`/contact?intent=${showRental ? "rental" : "sale"}&property=${encodeURIComponent(data.slug)}`}
        >
          {showSale && !showRental ? "Request info" : "Ask a question"}
        </a>
        <p class="property__response">
          We typically reply within one business day.
        </p>
        <ListingNotice />
        {
          listingTestimonials.length > 0 && (
            <Testimonials
              items={listingTestimonials}
              title="Guest ratings"
              compact
            />
          )
        }
      </aside>
    </div>

    <section class="property__section property__ratings" aria-label="Listing ratings and feedback">
      {
        listingTestimonials.length > 0 && (
          <Testimonials items={listingTestimonials} title="What guests say" />
        )
      }
      <RatingSubmit
        client:visible
        targetType="listing"
        targetId={data.slug}
        label={`Rate ${data.title}`}
      />
    </section>

    {
      related.length > 0 && (
        <section class="property__related" aria-labelledby="related-homes">
          <header class="property__related-head">
            <p class="property__eyebrow">Along the coast</p>
            <h2 id="related-homes">More homes worth a look</h2>
          </header>
          <div class="property__related-grid">
            {related.map((entry) => (
              <PropertyCard property={toPropertyCardProps(entry)} />
            ))}
          </div>
        </section>
      )
    }
  </article>

  <nav class="property__mobile-bar" aria-label="Property inquiry">
    {
      showRental && (
        <a class="property__mobile-bar-primary" href="#availability-inquiry">
          Check dates
        </a>
      )
    }
    {
      showSale && (
        <a
          class={showRental ? "property__mobile-bar-ghost" : "property__mobile-bar-primary"}
          href={saleHref}
        >
          Schedule showing
        </a>
      )
    }
  </nav>
</MarketingLayout>

<style>
  .property {
    padding-block: clamp(1.25rem, 2.5vw, 2rem) clamp(1.5rem, 3vw, 2.5rem);
  }

  .property__layout {
    display: grid;
    gap: 1.5rem 2rem;
    grid-template-columns: minmax(0, 1.4fr) minmax(16rem, 0.75fr);
    align-items: start;
    margin-top: 1.25rem;
  }

  .property__header h1 {
    margin: 0.35rem 0 0.75rem;
    font-size: clamp(1.85rem, 3.5vw, 2.75rem);
    line-height: 1.1;
  }

  .property__eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--muted-foreground);
  }

  .property__desc {
    max-width: 42rem;
    margin: 0;
    color: var(--muted-foreground);
    line-height: 1.55;
  }

  .property__price {
    margin: 0.85rem 0 0;
    font-size: 1.35rem;
    font-weight: 600;
  }

  .property__facts {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(5.5rem, 1fr));
    gap: 0.65rem;
    margin: 1.15rem 0 0;
    padding: 0;
  }

  .property__facts div {
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--card);
  }

  .property__facts dt {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .property__facts dd {
    margin: 0.2rem 0 0;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .property__aside {
    position: sticky;
    top: calc(var(--header-height) + 0.75rem);
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .property__response {
    margin: 0;
    color: var(--muted-foreground);
    font-size: 0.875rem;
    line-height: 1.45;
  }

  .property__ask {
    width: fit-content;
    border-bottom: 1px solid currentcolor;
    color: var(--foreground);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.1rem;
    background: var(--primary);
    color: var(--primary-foreground);
    font-weight: 600;
    text-decoration: none;
  }

  .property__section {
    margin-top: 2rem;
  }

  .property__section h2 {
    margin: 0 0 0.85rem;
    font-size: 1.25rem;
  }

  .highlights {
    display: grid;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .highlights li {
    padding-left: 1rem;
    border-left: 2px solid var(--primary);
    color: var(--foreground);
    line-height: 1.45;
  }

  .amenities {
    display: grid;
    gap: 0.5rem;
    grid-template-columns: repeat(auto-fill, minmax(10.5rem, 1fr));
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .amenities li {
    display: flex;
    align-items: center;
    min-height: 2.75rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--card);
    font-size: 0.92rem;
    line-height: 1.3;
  }

  .property__related {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .property__related-head {
    margin-bottom: 1.25rem;
  }

  .property__related-head h2 {
    margin: 0.35rem 0 0;
    font-size: 1.35rem;
    font-weight: 600;
  }

  .property__related-grid {
    display: grid;
    gap: 1.75rem;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
  }

  .property__mobile-bar {
    display: none;
  }

  @media (max-width: 48rem) {
    .property {
      padding-bottom: calc(4.5rem + env(safe-area-inset-bottom, 0px));
    }

    .property__layout {
      grid-template-columns: 1fr;
    }

    .property__aside {
      position: static;
    }

    .property__mobile-bar {
      position: fixed;
      inset-inline: 0;
      bottom: 0;
      z-index: var(--z-index-sticky);
      display: flex;
      gap: 0.5rem;
      padding: 0.65rem 1rem calc(0.65rem + env(safe-area-inset-bottom, 0px));
      border-top: 1px solid var(--border);
      background: var(--background);
    }

    .property__mobile-bar a {
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.75rem;
      padding: 0.55rem 0.75rem;
      font-weight: 600;
      text-align: center;
      text-decoration: none;
    }

    .property__mobile-bar-primary {
      background: var(--primary);
      color: var(--primary-foreground);
    }

    .property__mobile-bar-ghost {
      border: 1px solid var(--border);
      background: var(--card);
      color: var(--foreground);
    }
  }
</style>
