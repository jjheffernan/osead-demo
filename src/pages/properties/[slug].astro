---
import { render } from "astro:content";
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import JsonLd from "../../components/seo/JsonLd.astro";
import ListingNotice from "../../components/properties/ListingNotice.astro";
import PropertyGallery from "../../components/properties/PropertyGallery.svelte";
import AvailabilityInquiry from "../../components/properties/AvailabilityInquiry.svelte";
import {
  getPublishedProperties,
  type PropertyEntry,
} from "../../lib/properties";
import {
  buildRentalJsonLd,
  buildSaleJsonLd,
} from "../../lib/property-schema";

export async function getStaticPaths() {
  const properties = await getPublishedProperties();
  return properties.map((property) => ({
    params: { slug: property.data.slug },
    props: { property },
  }));
}

interface Props {
  property: PropertyEntry;
}

const { property } = Astro.props;
const { data } = property;
const { Content } = await render(property);
const locale = (Astro.currentLocale || "en") as "en";
const path = `/properties/${data.slug}`;
const pageUrl = new URL(path, Astro.site).toString();
const title = data.seoTitle ?? `${data.title} | ${data.regionLabel}`;
const description = data.seoDescription ?? data.description;
const saleLd = buildSaleJsonLd(data, pageUrl);
const rentalLd = buildRentalJsonLd(data, pageUrl);
const schemas = [saleLd, rentalLd].filter(Boolean) as Record<
  string,
  unknown
>[];
---

<MarketingLayout title={title} description={description} locale={locale} path={path}>
  {schemas.length > 0 && <JsonLd schema={schemas} />}

  <article class="container py-16 property">
    <PropertyGallery client:load images={data.images} label={`${data.title} gallery`} />

    <header class="property__header">
      <p class="property__eyebrow">{data.regionLabel} · {data.waterfront}</p>
      <h1>{data.title}</h1>
      <p class="property__desc">{data.description}</p>
      {
        data.priceDisplay && (
          <p class="property__price">{data.priceDisplay}</p>
        )
      }
      <p class="property__stats">
        {data.beds} beds · {data.baths} baths
        {data.sleeps ? ` · Sleeps ${data.sleeps}` : ""}
        {data.sqft ? ` · ${data.sqft.toLocaleString()} sq ft` : ""}
      </p>
      {
        (data.listingType === "sale" || data.listingType === "both") && (
          <div class="property__actions">
            <a class="button button--ghost" href="/contact">
              Schedule a showing
            </a>
          </div>
        )
      }
      {
        (data.listingType === "rental" || data.listingType === "both") && (
          <AvailabilityInquiry
            client:load
            propertySlug={data.slug}
            propertyTitle={data.title}
          />
        )
      }
      <ListingNotice />
    </header>

    {
      data.highlights.length > 0 && (
        <section class="property__section">
          <h2>Highlights</h2>
          <ul>
            {data.highlights.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )
    }

    {
      data.amenities.length > 0 && (
        <section class="property__section">
          <h2>Amenities</h2>
          <ul class="amenities">
            {data.amenities.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="property__section prose">
      <h2>About this home</h2>
      <Content />
    </section>
  </article>
</MarketingLayout>

<style>
  .property__header h1 {
    margin: 0.35rem 0 0.75rem;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
  }

  .property__eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.8rem;
    color: var(--muted-foreground);
  }

  .property__desc,
  .property__stats {
    max-width: 42rem;
    color: var(--muted-foreground);
  }

  .property__price {
    font-size: 1.35rem;
    font-weight: 600;
  }

  .property__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.1rem;
    background: var(--primary);
    color: var(--primary-foreground);
    text-decoration: none;
  }

  .button--ghost {
    background: transparent;
    color: var(--foreground);
    border: 1px solid var(--border);
  }

  .property__section {
    margin-top: 2.5rem;
  }

  .amenities {
    display: grid;
    gap: 0.4rem 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    padding-left: 1.1rem;
  }
</style>
