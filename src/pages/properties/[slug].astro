---
import { render } from "astro:content";
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import Breadcrumbs from "../../components/seo/Breadcrumbs.astro";
import JsonLd from "../../components/seo/JsonLd.astro";
import ListingNotice from "../../components/properties/ListingNotice.astro";
import PropertyCard from "../../components/properties/PropertyCard.astro";
import PropertyGallery from "../../components/properties/PropertyGallery.svelte";
import AvailabilityInquiry from "../../components/properties/AvailabilityInquiry.svelte";
import {
  getPublishedProperties,
  getRelatedProperties,
  type PropertyEntry,
} from "../../lib/properties";
import {
  buildRentalJsonLd,
  buildSaleJsonLd,
} from "../../lib/property-schema";

export async function getStaticPaths() {
  const properties = await getPublishedProperties();
  return properties.map((property) => ({
    params: { slug: property.data.slug },
    props: { property },
  }));
}

interface Props {
  property: PropertyEntry;
}

const { property } = Astro.props;
const { data } = property;
const { Content } = await render(property);
const locale = (Astro.currentLocale || "en") as "en";
const path = `/properties/${data.slug}`;
const pageUrl = new URL(path, Astro.site).toString();
const title = data.seoTitle ?? `${data.title} | ${data.regionLabel}`;
const description = data.seoDescription ?? data.description;
const saleLd = buildSaleJsonLd(data, pageUrl);
const rentalLd = buildRentalJsonLd(data, pageUrl);
const schemas = [saleLd, rentalLd].filter(Boolean) as Record<
  string,
  unknown
>[];
const listingLabel =
  data.listingType === "both"
    ? "Rental & sale"
    : data.listingType === "rental"
      ? "Weekly rental"
      : "For sale";
// Primary IA is Rentals/Sales; markets stay secondary SEO (V13 towns).
const inventoryCrumb =
  data.listingType === "sale"
    ? { label: "Homes for Sale", href: "/sales" }
    : { label: "Weekly Rentals", href: "/rentals" };
const related = await getRelatedProperties(property);
---

<MarketingLayout title={title} description={description} locale={locale} path={path}>
  {schemas.length > 0 && <JsonLd schema={schemas} />}

  <article class="container property">
    <Breadcrumbs
      crumbs={[inventoryCrumb, { label: data.title, href: path }]}
    />
    <PropertyGallery
      client:load
      images={data.images}
      videos={data.videos}
      label={`${data.title} gallery`}
    />

    <div class="property__layout">
      <header class="property__header">
        <p class="property__eyebrow">
          {listingLabel} · {data.regionLabel} · {data.waterfront}
        </p>
        <h1>{data.title}</h1>
        <p class="property__desc">{data.description}</p>
        {
          data.priceDisplay && (
            <p class="property__price">{data.priceDisplay}</p>
          )
        }
        <dl class="property__facts">
          <div>
            <dt>Beds</dt>
            <dd>{data.beds}</dd>
          </div>
          <div>
            <dt>Baths</dt>
            <dd>{data.baths}</dd>
          </div>
          {
            data.sleeps && (
              <div>
                <dt>Sleeps</dt>
                <dd>{data.sleeps}</dd>
              </div>
            )
          }
          {
            data.sqft && (
              <div>
                <dt>Sq ft</dt>
                <dd>{data.sqft.toLocaleString()}</dd>
              </div>
            )
          }
          {
            data.yearBuilt && (
              <div>
                <dt>Built</dt>
                <dd>{data.yearBuilt}</dd>
              </div>
            )
          }
        </dl>
      </header>

      <aside class="property__aside">
        {
          (data.listingType === "sale" || data.listingType === "both") && (
            <a
              class="button"
              href={`/contact?intent=sale&property=${encodeURIComponent(data.slug)}`}
            >
              Schedule a showing
            </a>
          )
        }
        {
          (data.listingType === "rental" || data.listingType === "both") && (
            <AvailabilityInquiry
              client:load
              propertySlug={data.slug}
              propertyTitle={data.title}
            />
          )
        }
        <ListingNotice />
      </aside>
    </div>

    {
      data.highlights.length > 0 && (
        <section class="property__section">
          <h2>Highlights</h2>
          <ul class="highlights">
            {data.highlights.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )
    }

    {
      data.amenities.length > 0 && (
        <section class="property__section">
          <h2>Amenities</h2>
          <ul class="amenities">
            {data.amenities.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="property__section prose">
      <h2>About this home</h2>
      <Content />
    </section>

    {
      related.length > 0 && (
        <section class="property__related" aria-labelledby="related-homes">
          <header class="property__related-head">
            <p class="property__eyebrow">Along the coast</p>
            <h2 id="related-homes">More homes worth a look</h2>
          </header>
          <div class="property__related-grid">
            {related.map((entry) => (
              <PropertyCard property={entry} />
            ))}
          </div>
        </section>
      )
    }
  </article>
</MarketingLayout>

<style>
  .property {
    padding-block: clamp(1.5rem, 3vw, 2.5rem) clamp(2.5rem, 5vw, 4rem);
  }

  .property__layout {
    display: grid;
    gap: 1.5rem 2rem;
    grid-template-columns: minmax(0, 1.4fr) minmax(16rem, 0.75fr);
    margin-top: 1.25rem;
  }

  .property__header h1 {
    margin: 0.35rem 0 0.75rem;
    font-size: clamp(1.85rem, 3.5vw, 2.75rem);
    line-height: 1.1;
  }

  .property__eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--muted-foreground);
  }

  .property__desc {
    max-width: 42rem;
    margin: 0;
    color: var(--muted-foreground);
    line-height: 1.55;
  }

  .property__price {
    margin: 0.85rem 0 0;
    font-size: 1.35rem;
    font-weight: 600;
  }

  .property__facts {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(5.5rem, 1fr));
    gap: 0.65rem;
    margin: 1.15rem 0 0;
    padding: 0;
  }

  .property__facts div {
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--card);
  }

  .property__facts dt {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .property__facts dd {
    margin: 0.2rem 0 0;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .property__aside {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.1rem;
    background: var(--primary);
    color: var(--primary-foreground);
    font-weight: 600;
    text-decoration: none;
  }

  .property__section {
    margin-top: 2rem;
  }

  .property__section h2 {
    margin: 0 0 0.85rem;
    font-size: 1.25rem;
  }

  .highlights {
    display: grid;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .highlights li {
    padding-left: 1rem;
    border-left: 2px solid var(--primary);
    color: var(--foreground);
    line-height: 1.45;
  }

  .amenities {
    display: grid;
    gap: 0.5rem;
    grid-template-columns: repeat(auto-fill, minmax(10.5rem, 1fr));
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .amenities li {
    display: flex;
    align-items: center;
    min-height: 2.75rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--card);
    font-size: 0.92rem;
    line-height: 1.3;
  }

  .property__related {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .property__related-head {
    margin-bottom: 1.25rem;
  }

  .property__related-head h2 {
    margin: 0.35rem 0 0;
    font-size: 1.35rem;
    font-weight: 600;
  }

  .property__related-grid {
    display: grid;
    gap: 1.75rem;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
  }

  @media (max-width: 48rem) {
    .property__layout {
      grid-template-columns: 1fr;
    }
  }
</style>
