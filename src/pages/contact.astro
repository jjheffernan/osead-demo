---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { t } from "../i18n/ui";
import { siteConfig } from "../config/site.config";
import Hero from "../components/hero/Hero.svelte";
import Button from "../components/ui/form/Button/Button.svelte";
import Icon from "../components/ui/primitives/Icon/Icon.astro";

const locale = (Astro.currentLocale || "en") as "en";

const allPages: CollectionEntry<"pages">[] = await getCollection("pages");
const page = allPages.find(
  (p) => p.data.slug === "contact" && p.data.locale === locale,
);

const allSettings = await getCollection("settings");
const settings = allSettings[0]?.data as
  | {
      mapLatitude?: string;
      mapLongitude?: string;
      orgName?: string;
      orgEmail?: string;
    }
  | undefined;

const lat = settings?.mapLatitude || "-6.2088";
const lng = settings?.mapLongitude || "106.8456";
const hasMap = Boolean(lat && lng);
const contactEmail = settings?.orgEmail || siteConfig.email;
// Query-param prefill (intent/property/dates) is applied client-side — this
// page is static, so Astro.url.searchParams are empty at build time.

// The interactive Google Maps embed is loaded on click (facade pattern) so its
// third-party JS never weighs on initial load (no TBT).
const mapEmbed = `https://maps.google.com/maps?q=${lat}%2C${lng}&z=15&hl=en&output=embed`;
const mapLink = `https://www.google.com/maps/search/?api=1&query=${lat}%2C${lng}`;

interface PageSection {
  type: string;
  title?: string;
  content?: string;
  items?: { title?: string; description?: string; icon?: string }[];
}

const sections: PageSection[] = page?.data.sections || [];
const heroSection = sections.find((s) => s.type === "hero");
const featuresSection = sections.find((s) => s.type === "features");

const iconByTitle: Record<string, string> = {
  Email: "lucide:mail",
  Office: "lucide:map-pin",
  Social: "lucide:at-sign",
  Phone: "lucide:phone",
};

const methods = (featuresSection?.items || []).map((item) => ({
  title: item.title || "",
  description: item.description || "",
  icon: iconByTitle[item.title || ""] || "lucide:circle",
}));
---

<BaseLayout
  title={page?.data.title || t(locale, "nav.contact")}
  description={page?.data.description}
  locale={locale}
  path={"/contact"}
>
  {
    heroSection && (
      <Hero
        variant="centered"
        size="md"
        eyebrow="Inquire"
        headline={heroSection.title || page?.data.title || ""}
        subheadline={heroSection.content}
        locale={locale}
      />
    )
  }

  <section class="contact container">
    <div class="contact__grid">
      <div class="contact__intro">
        <h2>Start a coastal conversation</h2>
        <p>
          Tell us about the week or home you are considering. We typically reply
          within one business day with availability or next steps — this is an
          inquiry, not a reservation.
        </p>
        <div
          id="inquiry-summary"
          class="contact__summary"
          aria-label="Inquiry summary"
          hidden
        >
          <p class="contact__summary-label">Your inquiry</p>
          <p id="inquiry-summary-text"></p>
        </div>
        <Button href={`mailto:${contactEmail}`} variant="primary">
          Email {contactEmail}
        </Button>

        <form
          id="contact-form"
          class="contact__form"
          action="/api/contact"
          method="post"
        >
          <input type="hidden" name="property" value="" />
          <input type="hidden" name="checkIn" value="" />
          <input type="hidden" name="checkOut" value="" />
          {/* Honeypot — leave empty. Bots that fill it are rejected by /api/contact. */}
          <div class="contact__honeypot" aria-hidden="true">
            <label>
              <span>Website</span>
              <input
                type="text"
                name="website"
                tabindex="-1"
                autocomplete="off"
              />
            </label>
          </div>
          <label>
            <span>Name</span>
            <input id="name" name="name" autocomplete="name" required />
          </label>
          <label>
            <span>Email</span>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
            />
          </label>
          <label>
            <span>I'm interested in</span>
            <select name="intent">
              <option value="rental">A weekly rental</option>
              <option value="sale">A home for sale</option>
              <option value="booking-inquiry"
                >Checking rental availability</option
              >
            </select>
          </label>
          <label class="contact__form-full">
            <span>How can we help?</span>
            <textarea
              id="message"
              name="message"
              rows="5"
              minlength="10"
              required
              placeholder="Tell us about your preferred week, questions, or showing."
            ></textarea>
          </label>
          <p id="form-error" class="contact__form-error" role="alert" hidden>
          </p>
          <div
            id="form-success"
            class="contact__form-success"
            role="status"
            hidden
          >
            <h3>Thank you</h3>
            <p>
              Your O-sea-D inquiry was received. We will follow up with
              availability or next steps. This is not a reservation or offer.
            </p>
          </div>
          <button id="submit-btn" type="submit">Send inquiry</button>
          <p class="contact__response">
            Demo inquiries only. Expect a reply within one business day.
          </p>
        </form>

        <ul class="contact__methods">
          {
            methods.map((method) => (
              <li class="contact__method">
                <span class="contact__method-icon" aria-hidden="true">
                  <Icon name={method.icon} />
                </span>
                <span class="contact__method-body">
                  <span class="contact__method-title">{method.title}</span>
                  <span class="contact__method-value">
                    {method.description}
                  </span>
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <aside class="contact__aside">
        {
          hasMap ? (
            <div class="contact__map">
              <button
                type="button"
                class="contact__map-facade"
                data-map-embed={mapEmbed}
                aria-label="Load interactive map"
              >
                <span class="contact__map-facade-grid" aria-hidden="true" />
                <span class="contact__map-facade-cta">
                  <Icon name="lucide:map-pin" />
                  <span>View map</span>
                </span>
              </button>
              <a
                class="contact__map-link"
                href={mapLink}
                target="_blank"
                rel="noopener noreferrer"
              >
                View on Google Maps
              </a>
            </div>
          ) : (
            <div class="contact__placeholder">
              <Icon name="lucide:map-pin" />
              <p>
                Add map coordinates in settings to show a location map here.
              </p>
            </div>
          )
        }
      </aside>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const contactForm = document.querySelector("#contact-form");
  // Static build cannot bake query params; apply availability deep-links here.
  (() => {
    if (!(contactForm instanceof HTMLFormElement)) return;
    const params = new URLSearchParams(location.search);
    const intents = new Set(["rental", "sale", "booking-inquiry"]);
    const intent = params.get("intent") || "";
    const property = (params.get("property") || "").trim().slice(0, 160);
    const dateOk = (v) => /^\d{4}-\d{2}-\d{2}$/.test(v || "");
    const checkIn = dateOk(params.get("checkIn")) ? params.get("checkIn") : "";
    const checkOut = dateOk(params.get("checkOut"))
      ? params.get("checkOut")
      : "";
    const select = contactForm.querySelector('select[name="intent"]');
    if (select instanceof HTMLSelectElement && intents.has(intent)) {
      select.value = intent;
    }
    for (const [name, value] of [
      ["property", property],
      ["checkIn", checkIn],
      ["checkOut", checkOut],
    ]) {
      const input = contactForm.querySelector(`input[name="${name}"]`);
      if (input instanceof HTMLInputElement) input.value = value || "";
    }
    if (!property) return;
    const summary = document.querySelector("#inquiry-summary");
    const text = document.querySelector("#inquiry-summary-text");
    if (!(summary instanceof HTMLElement) || !(text instanceof HTMLElement))
      return;
    const strong = document.createElement("strong");
    strong.textContent = property;
    text.replaceChildren(strong);
    if (checkIn && checkOut) {
      text.append(` · ${checkIn} to ${checkOut}`);
    }
    summary.hidden = false;
  })();

  contactForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (
      !(contactForm instanceof HTMLFormElement) ||
      !contactForm.reportValidity()
    )
      return;

    const button = contactForm.querySelector("#submit-btn");
    const success = contactForm.querySelector("#form-success");
    const error = contactForm.querySelector("#form-error");
    if (!(button instanceof HTMLButtonElement)) return;

    button.disabled = true;
    success?.setAttribute("hidden", "");
    error?.setAttribute("hidden", "");
    try {
      const response = await fetch(contactForm.action, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(Object.fromEntries(new FormData(contactForm))),
      });
      if (!response.ok) throw new Error("Request failed");
      contactForm.reset();
      contactForm.dataset.state = "thanks";
      success?.removeAttribute("hidden");
    } catch {
      if (error) {
        error.textContent =
          "We could not send your inquiry. Please email us instead.";
        error.removeAttribute("hidden");
      }
    } finally {
      button.disabled = false;
    }
  });

  // Swap the static facade for the real Google Maps iframe only on first click,
  // keeping third-party JS off the critical path.
  document.querySelectorAll("[data-map-embed]").forEach((btn) => {
    btn.addEventListener(
      "click",
      () => {
        const src = btn.getAttribute("data-map-embed");
        if (!src) return;
        const iframe = document.createElement("iframe");
        iframe.src = src;
        iframe.width = "100%";
        iframe.height = "320";
        iframe.loading = "lazy";
        iframe.title = "Location map";
        iframe.setAttribute("referrerpolicy", "no-referrer-when-downgrade");
        iframe.setAttribute("allowfullscreen", "");
        iframe.className = "contact__map-frame";
        btn.replaceWith(iframe);
      },
      { once: true },
    );
  });
</script>

<style>
  .contact {
    padding-block: var(--space-2xl) var(--space-3xl);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-2xl);
    align-items: start;
  }

  .contact__intro h2 {
    margin: 0 0 var(--space-sm);
    font-size: clamp(1.5rem, 2.5vw, 1.875rem);
    letter-spacing: -0.01em;
  }

  .contact__intro p {
    margin: 0 0 var(--space-lg);
    max-width: 42ch;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .contact__summary {
    margin: 0 0 var(--space-lg);
    padding: var(--space-md);
    border-left: 3px solid var(--color-brand-primary);
    background: var(--color-bg-secondary);
  }

  .contact__summary p {
    margin: 0;
  }

  .contact__summary-label {
    margin-bottom: var(--space-xs) !important;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .contact__form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  /* Hidden from humans; bots that autofill `website` are rejected server-side. */
  .contact__honeypot {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .contact__form[data-state="thanks"] label,
  .contact__form[data-state="thanks"] button,
  .contact__form[data-state="thanks"] .contact__honeypot {
    display: none;
  }

  .contact__form label {
    display: grid;
    gap: var(--space-xs);
    color: var(--color-text-primary);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .contact__form input,
  .contact__form select,
  .contact__form textarea {
    box-sizing: border-box;
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-primary);
    color: var(--color-text-primary);
    padding: var(--space-sm);
    font: inherit;
  }

  .contact__form textarea {
    resize: vertical;
  }

  .contact__form-full,
  .contact__form-error,
  .contact__form-success {
    grid-column: 1 / -1;
  }

  .contact__form button {
    justify-self: start;
    border: 1px solid var(--color-brand-primary);
    border-radius: var(--radius-md);
    background: var(--color-brand-primary);
    color: var(--color-bg-primary);
    padding: var(--space-sm) var(--space-lg);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .contact__response {
    grid-column: 1 / -1;
    margin: 0;
    max-width: none;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    line-height: 1.45;
  }

  .contact__form[data-state="thanks"] .contact__response {
    display: none;
  }

  .contact__form button:disabled {
    cursor: wait;
    opacity: 0.7;
  }

  .contact__form-error {
    margin: 0;
    color: var(--destructive);
  }

  .contact__form-success {
    margin: 0;
    padding: var(--space-lg);
    border-left: 3px solid var(--color-brand-primary);
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
  }

  .contact__form-success h3 {
    margin: 0 0 var(--space-sm);
    font-size: 1.25rem;
  }

  .contact__form-success p {
    margin: 0;
    max-width: none;
    color: var(--color-text-secondary);
  }

  .contact__methods {
    list-style: none;
    margin: var(--space-2xl) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-md);
  }

  .contact__method {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background: var(--color-bg-secondary);
  }

  .contact__method-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    border-radius: var(--radius-full);
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
  }

  .contact__method-body {
    display: grid;
    gap: 0.125rem;
  }

  .contact__method-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    color: var(--color-text-secondary);
  }

  .contact__method-value {
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .contact__aside {
    position: sticky;
    top: 5.5rem;
  }

  .contact__map :global(iframe),
  .contact__map-frame {
    display: block;
    width: 100%;
    height: 320px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
  }

  .contact__map-facade {
    position: relative;
    display: block;
    width: 100%;
    height: 320px;
    padding: 0;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background: var(--color-bg-secondary);
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .contact__map-facade:hover,
  .contact__map-facade:focus-visible {
    border-color: var(--color-text-primary);
    box-shadow: var(--shadow-md);
    outline: none;
  }

  /* Faint monochrome grid hinting at a map, drawn from tokens (no asset). */
  .contact__map-facade-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--color-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
    background-size: 2rem 2rem;
    opacity: 0.6;
    -webkit-mask-image: radial-gradient(
      circle at center,
      black 35%,
      transparent 75%
    );
    mask-image: radial-gradient(circle at center, black 35%, transparent 75%);
    pointer-events: none;
  }

  .contact__map-facade-cta {
    position: absolute;
    inset: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .contact__map-facade-cta :global(svg) {
    width: 1.125rem;
    height: 1.125rem;
  }

  .contact__map-link {
    display: inline-block;
    margin-top: var(--space-sm);
    color: var(--color-brand-primary);
    font-weight: 600;
    text-decoration: none;
  }

  .contact__map-link:hover {
    text-decoration: underline;
  }

  .contact__placeholder {
    display: grid;
    justify-items: center;
    gap: var(--space-sm);
    padding: var(--space-3xl) var(--space-lg);
    text-align: center;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-2xl);
    color: var(--color-text-secondary);
  }

  @media (max-width: 48rem) {
    .contact__grid {
      grid-template-columns: 1fr;
    }

    .contact__form {
      grid-template-columns: 1fr;
    }

    .contact__form-full,
    .contact__form-error,
    .contact__form-success {
      grid-column: auto;
    }

    .contact__aside {
      position: static;
    }
  }
</style>
