---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import ListingNotice from "../../components/properties/ListingNotice.svelte";
import CollectionLinks from "../../components/properties/CollectionLinks.svelte";
import ListingFilters from "../../components/properties/ListingFilters.svelte";
import { getPropertiesByListingType } from "../../lib/properties";

const locale = (Astro.currentLocale || "en") as "en";
const properties = await getPropertiesByListingType("rental");
const listings = properties.map(({ data }) => ({
  slug: data.slug,
  title: data.title,
  regionLabel: data.regionLabel,
  listingType: data.listingType,
  beds: data.beds,
  baths: data.baths,
  sleeps: data.sleeps,
  waterfront: data.waterfront,
  amenities: data.amenities,
  priceDisplay: data.priceDisplay,
  image: data.images[0],
}));
---

<MarketingLayout
  title="Weekly Beach Rentals"
  description="High-end weekly vacation rentals on the Outer Banks, Jersey Shore, and Delaware Beaches — oceanfront and near-beach homes."
  locale={locale}
  path="/rentals"
>
  <section class="container py-16">
    <header class="section-head">
      <p class="section-head__eyebrow">Weekly rentals</p>
      <h1 class="section-head__title">Coastal weeks worth returning for</h1>
      <p class="section-head__lead">
        Filter {properties.length} oceanfront and near-beach homes, then inquire
        on dates. Prefer a conversation first?
        <a class="section-head__cta" href="/contact?intent=rental">Contact us</a
        >.
      </p>
    </header>

    <ListingNotice />
    <CollectionLinks />

    <ListingFilters client:load listings={listings} listingType="rental" />
  </section>
</MarketingLayout>

<style>
  .section-head__cta {
    color: inherit;
    font-weight: 700;
    text-underline-offset: 0.15em;
  }
</style>
