---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { t } from "../i18n/ui";
import Team from "../components/sections/Team.svelte";
import Marquee from "../components/ui/Marquee.svelte";
import RatingsCarousel from "../components/testimonials/RatingsCarousel.svelte";
import RatingTabs from "../components/testimonials/RatingTabs.svelte";
import { demoStaff } from "../config/staff";
import { getTestimonialsFor } from "../lib/testimonials";

const locale = (Astro.currentLocale || "en") as "en";

const allPages: CollectionEntry<"pages">[] = await getCollection("pages");
const page = allPages.find(
  (p) => p.data.slug === "about" && p.data.locale === locale,
);

const [businessTestimonials, ...staffTestimonialGroups] = await Promise.all([
  getTestimonialsFor("business", "osead", locale),
  ...demoStaff.map((member) =>
    getTestimonialsFor("staff", member.id, locale),
  ),
]);
const staffTestimonials = staffTestimonialGroups.flat();
const ratingCarouselItems = [...businessTestimonials, ...staffTestimonials];

const coastMarquee = [
  "Outer Banks",
  "Jersey Shore",
  "Delaware Beaches",
  "Oceanfront",
  "Soundfront",
  "Bayfront",
  "Weekly stays",
  "Second homes",
  "Direct inquiry",
  "Equal housing",
];
---

<MarketingLayout
  title={page?.data.title || t(locale, "nav.about")}
  description={page?.data.description}
  locale={locale}
  path="/about"
>
  <section class="about-hero container">
    <div class="about-hero__copy">
      <p class="eyebrow">About O-sea-D</p>
      <h1>Coastal homes, matched by people who care.</h1>
      <p class="about-hero__lead">
        Weekly stays and second-home sales under one brand — with a human team
        on every inquiry. Demo inventory; never a checkout funnel.
      </p>
      <div class="about-hero__actions">
        <a class="about-hero__cta" href="/contact">Start an inquiry</a>
        <a class="about-hero__ghost" href="/rentals">Browse rentals</a>
        <a class="about-hero__ghost" href="/sales">Homes for sale</a>
      </div>
    </div>
    <aside class="about-hero__aside" aria-label="How we work">
      <h2 class="about-hero__aside-title">How we work</h2>
      <ol class="about-hero__steps">
        <li>
          <strong>Weekly stays</strong>
          Unhurried weeks by the water.
        </li>
        <li>
          <strong>Coastal ownership</strong>
          Local context, private showings.
        </li>
        <li>
          <strong>Direct guidance</strong>
          Real questions — not lead mills.
        </li>
      </ol>
    </aside>
  </section>

  <Marquee
    items={coastMarquee}
    label="Coastal markets and stay types we demonstrate"
    duration={42}
  />

  <Team
    title="Meet the demo team"
    description="Principal, rentals, sales, and guest experience — a boutique coastal group."
    members={demoStaff}
  />

  {
    ratingCarouselItems.length > 0 && (
      <RatingsCarousel
        client:visible
        items={ratingCarouselItems}
        title="What clients say"
        label="Client ratings carousel"
      />
    )
  }

  <RatingTabs client:visible />

  <section class="about-close">
    <div class="about-close__inner container">
      <h2>Ready when you are</h2>
      <p>Browse the collection, then tell us what you have in mind.</p>
      <div class="about-close__links">
        <a href="/rentals">Weekly rentals</a>
        <a href="/sales">Homes for sale</a>
        <a href="/contact">Inquire</a>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .eyebrow {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .about-hero {
    display: grid;
    gap: 1.75rem 2.5rem;
    grid-template-columns: 1.35fr 0.85fr;
    align-items: end;
    padding-block: clamp(1.75rem, 4vw, 2.75rem) 1.75rem;
  }

  .about-hero h1 {
    max-width: 14ch;
    margin: 0.4rem 0 0;
    font-size: clamp(1.85rem, 3.6vw, 2.85rem);
    letter-spacing: var(--tracking-tight);
    line-height: 1.08;
  }

  .about-hero__lead {
    max-width: 42ch;
    margin: 0.85rem 0 0;
    color: var(--muted-foreground);
    font-size: var(--text-base);
    line-height: 1.5;
  }

  .about-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1.35rem;
    margin-top: 1.25rem;
    align-items: center;
  }

  .about-hero__cta {
    display: inline-flex;
    padding: 0.65rem 1.1rem;
    background: var(--primary);
    color: var(--primary-foreground);
    font-weight: 700;
    text-decoration: none;
  }

  .about-hero__ghost {
    display: inline-block;
    margin-inline: 0.15rem;
    color: inherit;
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid currentcolor;
  }

  .about-hero__aside {
    padding: 1.15rem 1.2rem;
    border: 1px solid var(--border);
    background: color-mix(in oklab, var(--card) 80%, transparent);
  }

  .about-hero__aside-title {
    margin: 0 0 0.75rem;
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .about-hero__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
    counter-reset: step;
  }

  .about-hero__steps li {
    counter-increment: step;
    padding-left: 2rem;
    position: relative;
    line-height: 1.4;
    color: var(--muted-foreground);
  }

  .about-hero__steps li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0.1rem;
    width: 1.35rem;
    height: 1.35rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--border);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--foreground);
  }

  .about-hero__steps strong {
    display: block;
    color: var(--foreground);
    margin-bottom: 0.1rem;
  }

  .about-close {
    border-top: 1px solid var(--border);
    background: color-mix(in oklab, var(--muted) 40%, transparent);
  }

  .about-close__inner {
    padding-block: 1.35rem 1.75rem;
    text-align: center;
  }

  .about-close h2 {
    margin: 0;
  }

  .about-close p {
    margin: 0.45rem 0 0;
    color: var(--muted-foreground);
  }

  .about-close__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 1.1rem;
  }

  .about-close__links a {
    border-bottom: 1px solid currentcolor;
    color: inherit;
    font-weight: 700;
    text-decoration: none;
  }

  @media (max-width: 48rem) {
    .about-hero {
      grid-template-columns: 1fr;
    }
  }
</style>
