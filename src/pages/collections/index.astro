---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import {
  collectionPath,
  getIntentCollections,
} from "../../lib/properties";

const locale = (Astro.currentLocale || "en") as "en";
const intentCollections = await getIntentCollections();
---

<MarketingLayout
  title="Browse by Intent"
  description="SEO collection hubs for oceanfront, pet-friendly, large-group, and elevator homes — not markets."
  locale={locale}
  path="/collections"
>
  <section class="container py-16">
    <header class="section-head">
      <p class="section-head__eyebrow">Collections</p>
      <h1 class="section-head__title">Browse by how you stay</h1>
      <p class="section-head__lead">
        Intent hubs for oceanfront access, pets, group size, and elevators —
        independent of market geography.
      </p>
    </header>

    <ul class="collection-list">
      {
        intentCollections.map((collection) => (
          <li>
            <a href={collectionPath(collection)}>
              <h2>{collection.data.title}</h2>
              <p>{collection.data.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</MarketingLayout>

<style>
  .collection-list {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
  }

  .collection-list a {
    display: block;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
    color: inherit;
    text-decoration: none;
  }

  .collection-list h2 {
    margin: 0 0 0.4rem;
  }

  .collection-list p {
    margin: 0;
    color: var(--muted-foreground);
    max-width: 48rem;
  }
</style>
