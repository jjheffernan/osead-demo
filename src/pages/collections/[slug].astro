---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import JsonLd from "../../components/seo/JsonLd.astro";
import PropertyCard from "../../components/properties/PropertyCard.svelte";
import {
  collectionToFilterQuery,
  getIntentCollections,
  getPropertiesForCollection,
  toPropertyCardProps,
  type IntentCollectionEntry,
} from "../../lib/properties";
import { buildCollectionJsonLd } from "../../lib/property-schema";

export async function getStaticPaths() {
  const intentCollections = await getIntentCollections();
  return intentCollections.map((collection) => ({
    params: { slug: collection.data.slug },
    props: { collection },
  }));
}

interface Props {
  collection: IntentCollectionEntry;
}

const { collection } = Astro.props;
const locale = (Astro.currentLocale || "en") as "en";
const properties = await getPropertiesForCollection(collection.data.match);
const title = collection.data.seoTitle ?? collection.data.title;
const description =
  collection.data.seoDescription ?? collection.data.description;
const filterQuery = collectionToFilterQuery(collection.data.match);
const path = `/collections/${collection.data.slug}`;
const pageUrl = new URL(path, Astro.site).toString();
const schemas = buildCollectionJsonLd(
  { title: collection.data.title, description: collection.data.description },
  pageUrl,
  properties,
);
---

<MarketingLayout
  title={title}
  description={description}
  locale={locale}
  path={path}
>
  <JsonLd schema={schemas} />

  <section class="container py-16">
    <header class="section-head">
      <p class="section-head__eyebrow">Collection</p>
      <h1 class="section-head__title">{collection.data.title}</h1>
      <p class="section-head__lead">{collection.data.description}</p>
      <p class="match-notes">{collection.data.matchNotes}</p>
      <div class="collection-handoff">
        <a class="collection-handoff__primary" href={`/rentals${filterQuery}`}
          >Browse matching rentals</a
        >
        <a class="collection-handoff__ghost" href={`/sales${filterQuery}`}
          >Browse matching sales</a
        >
      </div>
    </header>

    <div class="property-grid">
      {
        properties.length > 0 ? (
          properties.map((property) => (
            <PropertyCard property={toPropertyCardProps(property)} />
          ))
        ) : (
          <p>No matching listings yet.</p>
        )
      }
    </div>
  </section>
</MarketingLayout>

<style>
  .match-notes {
    margin-top: 1rem;
    color: var(--muted-foreground);
    font-size: 0.95rem;
    max-width: 48rem;
  }

  .collection-handoff {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.1rem;
    margin-top: 1.25rem;
    align-items: center;
  }

  .collection-handoff__primary {
    display: inline-flex;
    padding: 0.65rem 1.05rem;
    background: var(--primary);
    color: var(--primary-foreground);
    font-weight: 700;
    text-decoration: none;
  }

  .collection-handoff__ghost {
    color: inherit;
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid currentcolor;
  }

  .property-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    margin-top: 2.5rem;
  }
</style>
