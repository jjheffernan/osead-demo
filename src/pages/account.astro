---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SEO from "../components/seo/SEO.astro";
import AdminShell from "../components/account/AdminShell.svelte";
import {
  getIntentCollections,
  getMarkets,
  getPropertiesByListingType,
} from "../lib/properties";

const locale = (Astro.currentLocale || "en") as "en";

const [rentals, sales, markets, collections, posts] = await Promise.all([
  getPropertiesByListingType("rental"),
  getPropertiesByListingType("sale"),
  getMarkets(),
  getIntentCollections(),
  getCollection("blog"),
]);

const inventory = [
  { href: "/rentals", label: "Rentals", count: rentals.length },
  { href: "/sales", label: "Sales", count: sales.length },
  { href: "/markets", label: "Markets", count: markets.length },
  { href: "/collections", label: "Collections", count: collections.length },
  { href: "/blog", label: "Journal", count: posts.length },
];

const walkthrough = [
  {
    title: "Listings",
    links: [
      { href: "/rentals", label: "Rentals", hint: "Filter + inquire" },
      { href: "/sales", label: "Sales", hint: "Filter + showing" },
      { href: "/collections", label: "Collections", hint: "Intent groups" },
    ],
  },
  {
    title: "Markets & story",
    links: [
      { href: "/markets", label: "Markets", hint: "Town pages" },
      { href: "/blog", label: "Journal", hint: "Editorial posts" },
      { href: "/about", label: "About", hint: "Team + ratings" },
    ],
  },
  {
    title: "Flows",
    links: [
      { href: "/contact", label: "Contact", hint: "Inquiry form" },
      { href: "/register", label: "Register", hint: "Signup path" },
      { href: "/login", label: "Login", hint: "Auth form" },
      { href: "/docs", label: "Docs", hint: "Starlight" },
    ],
  },
];
---

<BaseLayout
  title="Admin — O-sea-D"
  description="Local admin workspace for the O-sea-D coastal template."
  locale={locale}
  path="/account"
  showHeader={false}
  showFooter={false}
  showThemeToggle={false}
>
  <SEO
    slot="seo"
    title="Admin — O-sea-D"
    description="Local admin workspace for the O-sea-D coastal template."
    locale={locale}
    path="/account"
    ogImage={`/og/page/${locale}/account`}
  />

  <div data-account-root>
    <div class="account-gate container" data-account-signed-out hidden>
      <p class="account-gate__eyebrow">Demo account</p>
      <h1>No demo session yet</h1>
      <p>
        Sign in with the demo admin for the full workspace, or create any
        account for a plain user session.
      </p>
      <div class="account-gate__actions">
        <a class="account-gate__cta" href="/login">Sign in</a>
        <a class="account-gate__ghost" href="/register">Create account</a>
        <a class="account-gate__ghost" href="/">← Site home</a>
      </div>
    </div>

    <div data-account-user hidden>
      <section class="account-user container">
        <p class="account-gate__eyebrow">Demo account</p>
        <h1>Welcome, <span data-account-name></span></h1>
        <p class="account-user__meta">
          Signed in as <strong data-account-email></strong>.
          Session started <time data-account-at></time>.
        </p>
        <p>
          Admin tools appear only for
          <code>admin@osead.demo</code>. This session is a plain user.
        </p>
        <div class="account-gate__actions">
          <a class="account-gate__cta" href="/rentals">Browse rentals</a>
          <button type="button" class="account-user__signout" data-account-signout>
            Sign out
          </button>
        </div>
      </section>
    </div>

    <div data-account-admin hidden>
      <AdminShell
        client:load
        inventory={inventory}
        walkthrough={walkthrough}
        locale={locale}
      />
    </div>
  </div>
</BaseLayout>

<script>
  import {
    clearDemoAccount,
    readDemoAccount,
  } from "../lib/demo-account";

  const root = document.querySelector("[data-account-root]");
  const signedOut = root?.querySelector<HTMLElement>(
    "[data-account-signed-out]",
  );
  const userEl = root?.querySelector<HTMLElement>("[data-account-user]");
  const adminEl = root?.querySelector<HTMLElement>("[data-account-admin]");
  const signOutBtns = root?.querySelectorAll("[data-account-signout]");

  const account = readDemoAccount();

  if (!account) {
    if (signedOut) signedOut.hidden = false;
  } else if (account.role === "admin" && adminEl) {
    adminEl.hidden = false;
  } else if (userEl) {
    const nameEl = userEl.querySelector("[data-account-name]");
    const emailEl = userEl.querySelector("[data-account-email]");
    const atEl = userEl.querySelector("time[data-account-at]");
    if (nameEl) nameEl.textContent = account.name;
    if (emailEl) emailEl.textContent = account.email;
    if (atEl) {
      atEl.textContent = new Date(account.at).toLocaleString();
      atEl.setAttribute("datetime", account.at);
    }
    userEl.hidden = false;
  }

  signOutBtns?.forEach((btn) => {
    btn.addEventListener("click", () => {
      clearDemoAccount();
      window.location.assign("/login");
    });
  });
</script>

<style is:global>
  /* Account admin is an app shell — drop marketing main padding assumptions. */
  body:has([data-account-admin]:not([hidden])) #main-content {
    display: contents;
  }
</style>

<style>
  .account-gate,
  .account-user {
    max-width: 36rem;
    padding-block: clamp(2.5rem, 8vw, 5rem);
  }

  .account-gate__eyebrow {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .account-gate h1,
  .account-user h1 {
    margin: 0.35rem 0 0;
    font-size: clamp(1.75rem, 3vw, 2.25rem);
  }

  .account-gate p,
  .account-user p {
    margin: 0.75rem 0 0;
    color: var(--muted-foreground);
    line-height: 1.5;
  }

  .account-user__meta {
    font-size: var(--text-sm);
  }

  .account-gate__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1.15rem;
    margin-top: 1.35rem;
    align-items: center;
  }

  .account-gate__cta {
    display: inline-flex;
    padding: 0.65rem 1.1rem;
    background: var(--primary);
    color: var(--primary-foreground);
    font-weight: 700;
    text-decoration: none;
  }

  .account-gate__ghost {
    color: inherit;
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid currentcolor;
  }

  .account-user__signout {
    padding: 0.45rem 0.8rem;
    border: 1px solid var(--border);
    background: transparent;
    color: inherit;
    font: inherit;
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
  }
</style>
