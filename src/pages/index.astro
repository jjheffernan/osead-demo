---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import PropertyCard from "../components/properties/PropertyCard.astro";
import {
  getPropertiesByListingType,
  getPublishedProperties,
} from "../lib/properties";

const locale = (Astro.currentLocale || "en") as "en";
const [featured, rentals, sales] = await Promise.all([
  getPublishedProperties(),
  getPropertiesByListingType("rental"),
  getPropertiesByListingType("sale"),
]);
---

<MarketingLayout
  title="OSEAD — Coastal Rentals & Sales"
  description="A considered collection of coastal homes to rent by the week or make your own."
  locale={locale}
  path="/"
>
  <section class="home-hero">
    <div class="home-hero__grain" aria-hidden="true"></div>
    <div class="home-hero__content container">
      <p class="home-hero__kicker">Atlantic homes, deliberately kept</p>
      <h1 class="home-hero__wordmark">OSEAD</h1>
      <p class="home-hero__line">
        Find the house that brings you back to the water.
      </p>
      <p class="home-hero__intro">
        A considered collection of coastal homes for a week away or a life
        closer to the shore.
      </p>
    </div>
  </section>

  <section class="paths container" aria-labelledby="paths-heading">
    <header class="paths__heading">
      <p class="eyebrow">Choose your way to the coast</p>
      <h2 id="paths-heading">Stay awhile. Or stay for good.</h2>
    </header>
    <div class="paths__grid">
      <a class="path-card path-card--rent" href="/rentals">
        <span class="path-card__number" aria-hidden="true">01</span>
        <p class="path-card__eyebrow">Weekly rentals</p>
        <h3>Make room for everyone.</h3>
        <p>
          Oceanfront weeks, long-table dinners, and homes with enough beds for
          the whole group.
        </p>
        <span class="path-card__link"
          >Browse rentals <span aria-hidden="true">→</span></span
        >
      </a>
      <a class="path-card path-card--buy" href="/sales">
        <span class="path-card__number" aria-hidden="true">02</span>
        <p class="path-card__eyebrow">Homes for sale</p>
        <h3>Keep a key by the sea.</h3>
        <p>
          Second homes with a sense of place, and the rental potential to make
          the seasons work harder.
        </p>
        <span class="path-card__link"
          >Explore homes for sale <span aria-hidden="true">→</span></span
        >
      </a>
    </div>
  </section>

  <section class="inventory container" aria-labelledby="inventory-heading">
    <header class="inventory__head">
      <div>
        <p class="eyebrow">A few homes worth knowing</p>
        <h2 id="inventory-heading">Featured inventory</h2>
      </div>
      <a class="text-link" href="/rentals"
        >See all rentals <span aria-hidden="true">→</span></a
      >
    </header>
    <div class="property-grid">
      {featured.map((property) => <PropertyCard property={property} />)}
    </div>
  </section>

  <section class="collection">
    <div class="collection__content container">
      <div>
        <p class="eyebrow">One collection, two ways in</p>
        <h2>Homes that hold their value in more ways than one.</h2>
      </div>
      <p>
        Some homes are made for a single perfect week. Others become the place
        your family returns to for years. OSEAD keeps both paths in view.
      </p>
      <div class="collection__links">
        <a href="/rentals">View {rentals.length} rental homes</a>
        <a href="/sales">View {sales.length} homes for sale</a>
      </div>
    </div>
  </section>

  <section class="home-closing container">
    <p class="eyebrow">Start with the shoreline</p>
    <h2>Come for the week. Stay for the view.</h2>
    <a class="closing-link" href="/contact"
      >Talk with OSEAD <span aria-hidden="true">→</span></a
    >
  </section>
</MarketingLayout>

<style>
  .home-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: clamp(5rem, 13vw, 11rem);
    background: var(--surface-invert);
    color: var(--surface-invert-foreground);
  }

  .home-hero__grain {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.7;
    background:
      linear-gradient(
        105deg,
        color-mix(in srgb, var(--primary) 55%, transparent),
        transparent 40%
      ),
      repeating-linear-gradient(
        -7deg,
        transparent 0,
        transparent 15px,
        color-mix(in srgb, var(--surface-invert-foreground) 6%, transparent)
          16px,
        transparent 18px
      );
  }

  .home-hero__content {
    max-width: 70rem;
  }

  .home-hero__kicker,
  .eyebrow,
  .path-card__eyebrow {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .home-hero__wordmark {
    margin: 0.3rem 0 0;
    color: inherit;
    font-size: clamp(5rem, 19vw, 15rem);
    font-weight: var(--font-weight-medium);
    letter-spacing: -0.095em;
    line-height: 0.8;
  }

  .home-hero__line {
    max-width: 17ch;
    margin: clamp(2.5rem, 5vw, 5rem) 0 0;
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    line-height: var(--leading-tight);
  }

  .home-hero__intro {
    max-width: 46ch;
    margin: var(--spacing-5) 0 0;
    color: color-mix(
      in srgb,
      var(--surface-invert-foreground) 76%,
      transparent
    );
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  .paths,
  .inventory,
  .home-closing {
    padding-block: clamp(4.5rem, 9vw, 8rem);
  }

  .paths__heading {
    max-width: 35rem;
    margin-bottom: var(--spacing-7);
  }

  .paths h2,
  .inventory h2,
  .collection h2,
  .home-closing h2 {
    margin: var(--spacing-3) 0 0;
    font-size: var(--heading-h2);
    letter-spacing: var(--tracking-tight);
  }

  .paths__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .path-card {
    position: relative;
    display: flex;
    min-height: 24rem;
    flex-direction: column;
    padding: clamp(1.5rem, 4vw, 3.5rem);
    color: inherit;
    text-decoration: none;
    transition:
      background-color 180ms ease,
      color 180ms ease;
  }

  .path-card + .path-card {
    border-left: 1px solid var(--border);
  }

  .path-card--rent {
    background: var(--card);
  }

  .path-card--buy {
    background: var(--accent);
  }

  .path-card:hover {
    background: var(--surface-invert);
    color: var(--surface-invert-foreground);
  }

  .path-card__number {
    color: var(--muted-foreground);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .path-card__eyebrow {
    margin-top: auto;
  }

  .path-card h3 {
    max-width: 12ch;
    margin: var(--spacing-3) 0 0;
    font-size: var(--heading-h3);
    letter-spacing: var(--tracking-tight);
  }

  .path-card p:not(.path-card__eyebrow) {
    max-width: 36ch;
    margin: var(--spacing-4) 0 0;
    color: var(--muted-foreground);
    line-height: var(--leading-relaxed);
  }

  .path-card:hover p:not(.path-card__eyebrow),
  .path-card:hover .path-card__number {
    color: color-mix(
      in srgb,
      var(--surface-invert-foreground) 72%,
      transparent
    );
  }

  .path-card__link,
  .text-link,
  .closing-link {
    display: inline-block;
    width: fit-content;
    margin-top: var(--spacing-6);
    border-bottom: 1px solid currentcolor;
    color: inherit;
    font-weight: var(--font-weight-bold);
    text-decoration: none;
  }

  .inventory__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--spacing-5);
    margin-bottom: var(--spacing-7);
  }

  .property-grid {
    display: grid;
    gap: var(--grid-gap-lg);
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  .collection {
    background: var(--surface-invert);
    color: var(--surface-invert-foreground);
  }

  .collection__content {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(2rem, 7vw, 8rem);
    padding-block: clamp(4.5rem, 9vw, 8rem);
  }

  .collection .eyebrow {
    color: color-mix(
      in srgb,
      var(--surface-invert-foreground) 68%,
      transparent
    );
  }

  .collection__content > p {
    margin: 0;
    align-self: end;
    color: color-mix(
      in srgb,
      var(--surface-invert-foreground) 78%,
      transparent
    );
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  .collection__links {
    display: flex;
    grid-column: 1 / -1;
    flex-wrap: wrap;
    gap: var(--spacing-6);
  }

  .collection__links a {
    border-bottom: 1px solid currentcolor;
    color: inherit;
    font-weight: var(--font-weight-bold);
    text-decoration: none;
  }

  .home-closing {
    text-align: center;
  }

  .home-closing h2 {
    max-width: 15ch;
    margin-inline: auto;
  }

  .closing-link {
    margin-top: var(--spacing-7);
  }

  @media (max-width: 48rem) {
    .paths__grid,
    .collection__content {
      grid-template-columns: 1fr;
    }

    .path-card {
      min-height: 20rem;
    }

    .path-card + .path-card {
      border-top: 1px solid var(--border);
      border-left: 0;
    }

    .inventory__head {
      align-items: start;
      flex-direction: column;
    }

    .collection__links {
      grid-column: auto;
      flex-direction: column;
      gap: var(--spacing-4);
    }
  }
</style>
