---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import PropertyCard from "../components/properties/PropertyCard.svelte";
import MarketplaceLinks from "../components/sections/MarketplaceLinks.svelte";
import Team from "../components/sections/Team.svelte";
import Testimonials from "../components/testimonials/Testimonials.svelte";
import {
  buyMarketplaces,
} from "../config/marketplaces";
import { demoStaff } from "../config/staff";
import {
  getPropertiesByListingType,
  pickRandom,
  toPropertyCardProps,
} from "../lib/properties";
import { getTestimonialsFor } from "../lib/testimonials";

const locale = (Astro.currentLocale || "en") as "en";
const [rentals, sales, businessTestimonials] = await Promise.all([
  getPropertiesByListingType("rental"),
  getPropertiesByListingType("sale"),
  getTestimonialsFor("business", "osead", locale),
]);
const homeRentals = pickRandom(rentals, 3);
const homeSales = pickRandom(sales, 3);
---

<MarketingLayout
  title="O-sea-D — Coastal Rentals & Sales"
  description="A considered collection of coastal homes to rent by the week or make your own."
  locale={locale}
  path="/"
>
  <section class="home-hero">
    <img
      class="home-hero__media"
      src="/images/markets/hero-home.svg"
      alt="Atlantic horizon at dusk — O-sea-D demo home frame"
      width="1920"
      height="1080"
      fetchpriority="high"
      decoding="async"
    />
    <div class="home-hero__veil" aria-hidden="true"></div>
    <div class="home-hero__grain" aria-hidden="true"></div>
    <div class="home-hero__content container">
      <p class="home-hero__kicker">Atlantic homes, deliberately kept</p>
      <h1 class="home-hero__wordmark">O-sea-D</h1>
      <p class="home-hero__line">
        Weekly rentals first. Homes for sale beside them.
      </p>
      <div class="home-hero__actions">
        <a class="home-hero__cta" href="/rentals"
          >Browse {rentals.length} rentals</a
        >
        <a class="home-hero__cta home-hero__cta--ghost" href="/sales"
          >{sales.length} homes for sale</a
        >
      </div>
    </div>
  </section>

  <section class="inventory container" aria-labelledby="rentals-heading">
    <header class="inventory__head">
      <div>
        <p class="eyebrow">Weekly stays</p>
        <h2 id="rentals-heading">Featured rentals</h2>
      </div>
      <a class="text-link" href="/rentals"
        >See all {rentals.length} rentals <span aria-hidden="true">→</span></a
      >
    </header>
    <div class="property-grid property-grid--featured">
      {homeRentals.map((property) => (
        <PropertyCard property={toPropertyCardProps(property)} featured />
      ))}
    </div>
  </section>

  <section class="inventory inventory--tight container" aria-labelledby="sales-heading">
    <header class="inventory__head">
      <div>
        <p class="eyebrow">Ownership</p>
        <h2 id="sales-heading">Homes for sale</h2>
      </div>
      <a class="text-link" href="/sales"
        >See all {sales.length} listings <span aria-hidden="true">→</span></a
      >
    </header>
    <div class="property-grid property-grid--featured">
      {homeSales.map((property) => (
        <PropertyCard property={toPropertyCardProps(property)} featured />
      ))}
    </div>
  </section>

  <MarketplaceLinks
    id="buy-platforms"
    eyebrow="Buy on the open market"
    title="Popular sites for homes for sale"
    lead="When you want national MLS context beyond this collection, start with the tools buyers already know."
    links={buyMarketplaces}
  />

  <section class="collection" aria-labelledby="collection-heading">
    <div class="collection__content container">
      <div>
        <p class="eyebrow">One collection, two ways in</p>
        <h2 id="collection-heading">
          Homes that hold their value in more ways than one.
        </h2>
      </div>
      <p>
        Some homes are made for a single perfect week. Others become the place
        your family returns to for years. O-sea-D keeps both paths in view.
      </p>
      <div class="collection__links">
        <a href="/rentals">View {rentals.length} rental homes</a>
        <a href="/sales">View {sales.length} homes for sale</a>
        <a href="/about">Meet the team</a>
      </div>
    </div>
  </section>

  <Team
    title="People behind the keys"
    description="Real estate is personal. This demo staff shows how a boutique coastal team can stay human — even in a template."
    members={demoStaff}
  />

  {
    businessTestimonials.length > 0 && (
      <section class="home-trust container">
        <Testimonials
          items={businessTestimonials}
          title="Trusted coastal guidance"
          compact
        />
      </section>
    )
  }

  <section class="home-closing container">
    <p class="eyebrow">Start with the shoreline</p>
    <h2>Come for the week. Stay for the view.</h2>
    <div class="home-closing__actions">
      <a class="closing-link" href="/contact"
        >Talk with O-sea-D <span aria-hidden="true">→</span></a
      >
      <a class="closing-link closing-link--muted" href="/about">About the team</a>
    </div>
  </section>
</MarketingLayout>

<style>
  .home-hero {
    /* Always a dark media plane — --surface-invert flips to cream in .dark */
    --hero-ink: oklch(0.25 0.035 235deg);
    --hero-foam: oklch(0.97 0.014 85deg);
    position: relative;
    isolation: isolate;
    display: grid;
    align-items: end;
    min-height: clamp(28rem, 78vh, 44rem);
    overflow: hidden;
    background: var(--hero-ink);
    color: var(--hero-foam);
  }

  .home-hero__media {
    position: absolute;
    inset: 0;
    z-index: -3;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .home-hero__veil {
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(
        to top,
        color-mix(in srgb, var(--hero-ink) 92%, transparent) 0%,
        color-mix(in srgb, var(--hero-ink) 48%, transparent) 45%,
        color-mix(in srgb, var(--hero-ink) 18%, transparent) 100%
      );
  }

  .home-hero__grain {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.22;
    background:
      linear-gradient(
        105deg,
        color-mix(in srgb, var(--primary) 28%, transparent),
        transparent 42%
      ),
      repeating-linear-gradient(
        -7deg,
        transparent 0,
        transparent 15px,
        color-mix(in srgb, var(--hero-foam) 5%, transparent) 16px,
        transparent 18px
      );
  }

  .home-hero__content {
    max-width: 70rem;
    padding-block: clamp(2rem, 5vw, 4rem);
  }

  .home-hero__kicker,
  .eyebrow {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .home-hero__wordmark {
    margin: 0.3rem 0 0;
    color: inherit;
    font-size: clamp(3.5rem, 14vw, 10rem);
    font-weight: var(--font-weight-medium);
    letter-spacing: -0.04em;
    line-height: 0.85;
  }

  .home-hero__line {
    max-width: 22ch;
    margin: clamp(1.5rem, 3vw, 2.75rem) 0 0;
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    line-height: var(--leading-tight);
  }

  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: var(--spacing-6);
  }

  .home-hero__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.1rem;
    background: var(--hero-foam);
    color: var(--hero-ink);
    font-weight: var(--font-weight-bold);
    text-decoration: none;
  }

  .home-hero__cta--ghost {
    background: transparent;
    color: var(--hero-foam);
    border: 1px solid color-mix(in srgb, var(--hero-foam) 45%, transparent);
  }

  .inventory,
  .home-trust,
  .home-closing {
    padding-block: clamp(1.5rem, 3vw, 2.5rem);
  }

  .inventory--tight {
    padding-top: 0;
  }

  .inventory h2,
  .collection h2,
  .home-closing h2 {
    margin: var(--spacing-2) 0 0;
    font-size: var(--heading-h2);
    letter-spacing: var(--tracking-tight);
  }

  .text-link,
  .closing-link {
    display: inline-block;
    width: fit-content;
    margin-top: var(--spacing-3);
    border-bottom: 1px solid currentcolor;
    color: inherit;
    font-weight: var(--font-weight-bold);
    text-decoration: none;
  }

  .inventory__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--spacing-4);
    margin-bottom: var(--spacing-5);
  }

  .property-grid {
    display: grid;
    gap: var(--grid-gap-md, 1.25rem);
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  }

  .property-grid--featured {
    gap: clamp(1rem, 2vw, 1.5rem);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  /* High-contrast band — explicit colors so the headline never washes out */
  .collection {
    background: var(--primary);
    color: var(--primary-foreground);
  }

  .collection__content {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(1.25rem, 4vw, 3rem);
    padding-block: clamp(1.5rem, 3vw, 2.5rem);
  }

  .collection .eyebrow {
    color: color-mix(in srgb, var(--primary-foreground) 72%, transparent);
  }

  .collection h2 {
    color: var(--primary-foreground);
  }

  .collection__content > p {
    margin: 0;
    align-self: end;
    color: color-mix(in srgb, var(--primary-foreground) 88%, transparent);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  .collection__links {
    display: flex;
    grid-column: 1 / -1;
    flex-wrap: wrap;
    gap: var(--spacing-5);
  }

  .collection__links a {
    border-bottom: 1px solid currentcolor;
    color: var(--primary-foreground);
    font-weight: var(--font-weight-bold);
    text-decoration: none;
  }

  .home-closing {
    text-align: center;
  }

  .home-closing h2 {
    max-width: 15ch;
    margin-inline: auto;
  }

  .home-closing__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-5);
    margin-top: var(--spacing-5);
  }

  .closing-link {
    margin-top: 0;
  }

  .closing-link--muted {
    color: var(--muted-foreground);
  }

  @media (max-width: 48rem) {
    .collection__content {
      grid-template-columns: 1fr;
    }

    .property-grid--featured {
      grid-template-columns: 1fr;
    }

    .inventory__head {
      align-items: start;
      flex-direction: column;
    }

    .collection__links {
      grid-column: auto;
      flex-direction: column;
      gap: var(--spacing-3);
    }
  }
</style>
