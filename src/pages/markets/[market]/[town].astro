---
import MarketingLayout from "../../../layouts/MarketingLayout.astro";
import Breadcrumbs from "../../../components/seo/Breadcrumbs.astro";
import MarketHero from "../../../components/markets/MarketHero.astro";
import PropertyCard from "../../../components/properties/PropertyCard.astro";
import { slugify } from "../../../lib/utils";
import {
  getMarkets,
  getPropertiesByTown,
  marketPath,
  townPath,
  type MarketEntry,
} from "../../../lib/properties";

export async function getStaticPaths() {
  const markets = await getMarkets();
  return markets.flatMap((market) =>
    market.data.towns.map((town: string) => ({
      params: { market: market.data.slug, town: slugify(town) },
      props: { market, town },
    })),
  );
}

interface Props {
  market: MarketEntry;
  town: string;
}

const { market, town } = Astro.props;
const locale = (Astro.currentLocale || "en") as "en";
const path = townPath(market, town);
const properties = await getPropertiesByTown(market.data.market, town);
const title = `${town} Beach Homes for Rent & Sale | O-sea-D`;
const description = `Browse weekly rentals and homes for sale in ${town}, ${market.data.title}.`;
const heroImage =
  market.data.heroImage ?? "/images/markets/hero-markets-index.svg";
---

<MarketingLayout
  title={title}
  description={description}
  locale={locale}
  path={path}
>
  <MarketHero
    image={heroImage}
    alt={`${town} in ${market.data.title}`}
    eyebrow={market.data.title}
    title={town}
    lead={`Homes in ${town} within the ${market.data.title} market — weekly rentals and sales.`}
  >
    <Breadcrumbs
      slot="crumbs"
      crumbs={[
        { label: "Markets", href: "/markets" },
        { label: market.data.title, href: marketPath(market) },
        { label: town, href: path },
      ]}
    />
  </MarketHero>

  <section class="container market-detail">
    <div class="property-grid">
      {
        properties.length > 0 ? (
          properties.map((property) => <PropertyCard property={property} />)
        ) : (
          <p>Listings for {town} are coming soon.</p>
        )
      }
    </div>
  </section>
</MarketingLayout>

<style>
  .market-detail {
    padding-block: clamp(2.5rem, 5vw, 4rem) clamp(3rem, 6vw, 5rem);
  }

  .property-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
</style>
