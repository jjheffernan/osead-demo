---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import Breadcrumbs from "../../components/seo/Breadcrumbs.astro";
import MarketHero from "../../components/markets/MarketHero.svelte";
import PropertyCard from "../../components/properties/PropertyCard.svelte";
import {
  getMarkets,
  getPropertiesByMarket,
  marketPath,
  townPath,
  toPropertyCardProps,
  type MarketEntry,
} from "../../lib/properties";

export async function getStaticPaths() {
  const markets = await getMarkets();
  return markets.map((market) => ({
    params: { slug: market.data.slug },
    props: { market },
  }));
}

interface Props {
  market: MarketEntry;
}

const { market } = Astro.props;
const locale = (Astro.currentLocale || "en") as "en";
const path = marketPath(market);
const properties = await getPropertiesByMarket(market.data.market);
const title = market.data.seoTitle ?? market.data.title;
const description = market.data.seoDescription ?? market.data.description;
const heroImage =
  market.data.heroImage ?? "/images/markets/hero-markets-index.svg";
---

<MarketingLayout
  title={title}
  description={description}
  locale={locale}
  path={path}
>
  <MarketHero
    image={heroImage}
    alt={`${market.data.title} shoreline`}
    eyebrow="Market guide"
    title={market.data.title}
    lead={market.data.description}
  >
    <Breadcrumbs
      slot="crumbs"
      crumbs={[
        { label: "Markets", href: "/markets" },
        { label: market.data.title, href: path },
      ]}
    />
    {
      market.data.towns.length > 0 && (
        <ul class="towns">
          {market.data.towns.map((town: string) => (
            <li>
              <a href={townPath(market, town)}>{town}</a>
            </li>
          ))}
        </ul>
      )
    }
  </MarketHero>

  <section class="container market-detail">
    <header class="market-detail__head">
      <div>
        <p class="market-detail__eyebrow">Inventory in this market</p>
        <h2>Homes to rent or buy</h2>
        <p>
          Markets are SEO depth — primary browse stays on filtered rentals and
          sales.
        </p>
      </div>
      <div class="market-detail__cta">
        <a
          class="market-detail__primary"
          href={`/rentals?market=${encodeURIComponent(market.data.market)}`}
          >Browse rentals here</a
        >
        <a
          class="market-detail__ghost"
          href={`/sales?market=${encodeURIComponent(market.data.market)}`}
          >Homes for sale here</a
        >
      </div>
    </header>
    <div class="property-grid">
      {
        properties.length > 0 ? (
          properties.map((property) => (
            <PropertyCard property={toPropertyCardProps(property)} />
          ))
        ) : (
          <p>Listings for this market are coming soon.</p>
        )
      }
    </div>
  </section>
</MarketingLayout>

<style>
  .towns {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 1.1rem;
    list-style: none;
    margin: 0.35rem 0 0;
    padding: 0;
  }

  .towns a {
    color: color-mix(
      in srgb,
      var(--surface-invert-foreground) 88%,
      transparent
    );
    text-decoration: none;
    border-bottom: 1px solid
      color-mix(in srgb, var(--surface-invert-foreground) 35%, transparent);
  }

  .towns a:hover {
    color: var(--surface-invert-foreground);
    border-bottom-color: var(--surface-invert-foreground);
  }

  .market-detail {
    padding-block: clamp(1.5rem, 3vw, 2.5rem) clamp(1.75rem, 3.5vw, 3rem);
  }

  .market-detail__head {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    align-items: flex-end;
  }

  .market-detail__eyebrow {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .market-detail__head h2 {
    margin: 0.3rem 0 0;
    font-size: 1.35rem;
  }

  .market-detail__head p {
    margin: 0.4rem 0 0;
    max-width: 40ch;
    color: var(--muted-foreground);
    font-size: var(--text-sm);
  }

  .market-detail__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    align-items: center;
  }

  .market-detail__primary {
    display: inline-flex;
    padding: 0.6rem 1rem;
    background: var(--primary);
    color: var(--primary-foreground);
    font-weight: 700;
    text-decoration: none;
  }

  .market-detail__ghost {
    color: inherit;
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid currentcolor;
  }

  .property-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
</style>
