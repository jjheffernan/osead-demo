---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import Breadcrumbs from "../../components/seo/Breadcrumbs.astro";
import MarketHero from "../../components/markets/MarketHero.astro";
import PropertyCard from "../../components/properties/PropertyCard.astro";
import {
  getMarkets,
  getPropertiesByMarket,
  marketPath,
  townPath,
  type MarketEntry,
} from "../../lib/properties";

export async function getStaticPaths() {
  const markets = await getMarkets();
  return markets.map((market) => ({
    params: { slug: market.data.slug },
    props: { market },
  }));
}

interface Props {
  market: MarketEntry;
}

const { market } = Astro.props;
const locale = (Astro.currentLocale || "en") as "en";
const path = marketPath(market);
const properties = await getPropertiesByMarket(market.data.market);
const title = market.data.seoTitle ?? market.data.title;
const description = market.data.seoDescription ?? market.data.description;
const heroImage =
  market.data.heroImage ?? "/images/markets/hero-markets-index.svg";
---

<MarketingLayout
  title={title}
  description={description}
  locale={locale}
  path={path}
>
  <MarketHero
    image={heroImage}
    alt={`${market.data.title} shoreline`}
    eyebrow="Market guide"
    title={market.data.title}
    lead={market.data.description}
  >
    <Breadcrumbs
      slot="crumbs"
      crumbs={[
        { label: "Markets", href: "/markets" },
        { label: market.data.title, href: path },
      ]}
    />
    {
      market.data.towns.length > 0 && (
        <ul class="towns">
          {market.data.towns.map((town) => (
            <li>
              <a href={townPath(market, town)}>{town}</a>
            </li>
          ))}
        </ul>
      )
    }
  </MarketHero>

  <section class="container market-detail">
    <div class="property-grid">
      {
        properties.length > 0 ? (
          properties.map((property) => <PropertyCard property={property} />)
        ) : (
          <p>Listings for this market are coming soon.</p>
        )
      }
    </div>
  </section>
</MarketingLayout>

<style>
  .towns {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 1.1rem;
    list-style: none;
    margin: 0.35rem 0 0;
    padding: 0;
  }

  .towns a {
    color: color-mix(
      in srgb,
      var(--surface-invert-foreground) 88%,
      transparent
    );
    text-decoration: none;
    border-bottom: 1px solid
      color-mix(in srgb, var(--surface-invert-foreground) 35%, transparent);
  }

  .towns a:hover {
    color: var(--surface-invert-foreground);
    border-bottom-color: var(--surface-invert-foreground);
  }

  .market-detail {
    padding-block: clamp(2.5rem, 5vw, 4rem) clamp(3rem, 6vw, 5rem);
  }

  .property-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
</style>
