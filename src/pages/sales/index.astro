---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import ListingNotice from "../../components/properties/ListingNotice.svelte";
import CollectionLinks from "../../components/properties/CollectionLinks.svelte";
import ListingFilters from "../../components/properties/ListingFilters.svelte";
import { getPropertiesByListingType } from "../../lib/properties";

const locale = (Astro.currentLocale || "en") as "en";
const properties = await getPropertiesByListingType("sale");
const listings = properties.map(({ data }) => ({
  slug: data.slug,
  title: data.title,
  regionLabel: data.regionLabel,
  listingType: data.listingType,
  beds: data.beds,
  baths: data.baths,
  sleeps: data.sleeps,
  waterfront: data.waterfront,
  amenities: data.amenities,
  priceDisplay: data.priceDisplay,
  image: data.images[0],
}));
---

<MarketingLayout
  title="Beach Homes for Sale"
  description="High-end oceanfront, bayfront, and ocean-block homes for sale across the Outer Banks, Jersey Shore, and Delaware Beaches."
  locale={locale}
  path="/sales"
>
  <section class="container py-16">
    <header class="section-head">
      <p class="section-head__eyebrow">Homes for sale</p>
      <h1 class="section-head__title">Second homes on the water</h1>
      <p class="section-head__lead">
        Browse {properties.length} listings with filters, then request a showing.
        Ready to talk?
        <a class="section-head__cta" href="/contact?intent=sale">Contact us</a>.
      </p>
    </header>

    <ListingNotice />
    <CollectionLinks />

    <ListingFilters client:load listings={listings} listingType="sale" />
  </section>
</MarketingLayout>

<style>
  .section-head__cta {
    color: inherit;
    font-weight: 700;
    text-underline-offset: 0.15em;
  }
</style>
