---
import JsonLd from "./JsonLd.astro";
import Breadcrumb from "../ui/navigation/Breadcrumb/Breadcrumb.svelte";

export interface Crumb {
  label: string;
  href: string;
}

export interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props as Props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [{ label: "Home", href: "/" }, ...crumbs].map(
    (crumb, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: crumb.label,
      item: crumb.href,
    }),
  ),
};
---

<Breadcrumb items={crumbs} includeHome={true} />
<JsonLd schema={jsonLd} />
