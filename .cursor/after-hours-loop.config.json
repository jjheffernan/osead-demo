{
  "repo": "jjheffernan/osead-demo",
  "baseBranch": "main",
  "packageManager": "pnpm",
  "testCommand": "pnpm build",
  "todoPath": "TODO.md",
  "statePath": ".cursor/after-hours-loop.state.json",
  "morningBriefPath": ".cursor/after-hours-morning-brief.md",
  "cloudLedgerPath": null,
  "runsPath": ".cursor/after-hours-runs",
  "draftPrs": false,
  "maxPrs": 999,
  "allowSkipTests": false,
  "allowEmptyQueue": false,
  "maxConsecutiveBlocked": 3,
  "babysitCi": false,
  "stopOnCiRed": false,
  "tickIntervalMinutes": 5,
  "maxRuntimeHours": 24,
  "priority": "todo-first",
  "defaultOutcomeKind": "branch-only",
  "localMerge": true,
  "skipGithubPr": true,
  "preferSubagents": true,
  "verticalSliceSubagent": true,
  "safety": {
    "pathDenylist": [".env", ".env.*", "**/*secret*", "**/*credential*"],
    "stopOnAuthWeakening": true,
    "stopOnDirtyTree": true
  }
}
